# Strapi v5 server base URL (no trailing slash and no /admin path)
STRAPI_URL=https://your-strapi-server.com

# Read-only API token from Strapi Admin → Settings → API Tokens
# Leave blank if the collections are publicly readable
STRAPI_API_TOKEN=

# Neon PostgreSQL connection string (used for contact form submissions)
# Get from Neon console → your project → Connection Details → Connection string
NEON_DATABASE_URL=
