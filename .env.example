# Connection string for your Postgres database.
# Local: postgres://user:password@localhost:5432/epyc
# Neon:  postgres://user:password@ep-xxx.neon.tech/epyc?sslmode=require
DATABASE_URI=

# A long, random string used by Payload to sign JWTs and cookies.
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# Cloudflare R2 (S3-compatible) for Payload media uploads.
# R2_ENDPOINT looks like: https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
