# Database lives in Cloudflare D1 (binding `DB`) — no connection string here.
# Local dev points at a wrangler-managed SQLite file under .wrangler/; the
# binding is wired via getCloudflareContext() in payload.config.ts.
# Apply schema:  pnpm db:migrate:local
# Seed CSVs:     pnpm db:seed:local

# A long, random string used by Payload to sign JWTs and cookies.
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# Cloudflare R2 (S3-compatible) for Payload media uploads.
# R2_ENDPOINT looks like: https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=local-epyc-website
R2_ENDPOINT=https://0c8b62b41dae270982a809b5df68a93d.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=2b2450e1f97eb437385a17979fe20484
R2_SECRET_ACCESS_KEY=1c24d1aaef7214b36e5f7ee196285b1968c74381dbc807cbe005e04cec3ec208
