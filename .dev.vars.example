# Used by `wrangler dev` / `pnpm preview` to inject secrets into the local
# Cloudflare Workers sandbox. NOT read by `pnpm dev` (which uses `.env`).
# Copy to `.dev.vars` and fill in real values when you want to test the
# Workers build locally.

PAYLOAD_SECRET=
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
